// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id                Int               @id @default(autoincrement())
  name              String?
  surname           String?
  username          String?           // @unique -- Add unique after making required
  email             String            @unique
  phone             String?
  passwordHash      String?
  role              Role              @default(USER)
  createdAt         DateTime          @default(now())
  isVerified        Boolean           @default(false)
  avatarUrl         String?
  progress          Json?
  savedLessons      Int[]             // Array of lesson IDs
  quizSubmissions   QuizSubmission[]  // Relation to quiz submissions
  completedChallenges Int[]           // Array of challenge IDs
  premiumStatus     PremiumStatus     @default(FREE)
  dailyLoginPoints  Int               @default(0)
  lastLoginDate     DateTime?
  visitedLessons    Json?
}

model Tutorial {
  id           Int                     @id @default(autoincrement())
  slug         String                  @unique
  translations TutorialTranslation[]
}

model TutorialTranslation {
  id          Int      @id @default(autoincrement())
  tutorialId  Int
  language    String
  title       String
  description String
  content     Json

  tutorial    Tutorial @relation(fields: [tutorialId], references: [id])
}

model QuizSubmission {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  quizId     Int
  score      Float
  timestamp  DateTime @default(now())
  answers    Json     // Store answers as JSON for flexibility
}

enum Role {
  USER
  ADMIN
}

enum PremiumStatus {
  FREE
  STANDARD
  PREMIUM
}
