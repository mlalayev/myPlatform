// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Tutorial {
  id           Int                     @id @default(autoincrement())
  slug         String                  @unique
  translations TutorialTranslation[]
}

model TutorialTranslation {
  id          Int      @id @default(autoincrement())
  tutorialId  Int
  language    String
  title       String
  description String
  content     Json

  tutorial    Tutorial @relation(fields: [tutorialId], references: [id])
}

enum Role {
  USER
  ADMIN
}
