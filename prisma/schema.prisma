// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id                Int               @id @default(autoincrement())
  name              String?
  surname           String?
  username          String?           // @unique -- Add unique after making required
  email             String            @unique
  phone             String?
  passwordHash      String?
  role              Role              @default(USER)
  createdAt         DateTime          @default(now())
  isVerified        Boolean           @default(false)
  avatarUrl         String?
  progress          Json?
  savedLessons      Int[]             // Array of lesson IDs
  quizSubmissions   QuizSubmission[]  // Relation to quiz submissions
  completedChallenges Int[]           // Array of challenge IDs
  solvedExercises   Int[]             // Array of solved exercise IDs
  premiumStatus     PremiumStatus     @default(FREE)
  dailyLoginPoints  Int               @default(0)
  lastLoginDate     DateTime?
  visitedLessons    Json?
  
  // New relations for activity tracking
  activities        UserActivity[]
  sessions          UserSession[]
  dailyActivities   DailyActivity[]
  achievements      Achievement[]
}

model Tutorial {
  id           Int                     @id @default(autoincrement())
  slug         String                  @unique
  published    Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations TutorialTranslation[]
}

model TutorialTranslation {
  id          Int      @id @default(autoincrement())
  tutorialId  Int
  language    String
  title       String
  description String
  content     Json

  tutorial    Tutorial @relation(fields: [tutorialId], references: [id])
}

model Exercise {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  difficulty  String   // EASY, MEDIUM, HARD
  category    String   // ALGORITHMS, DATA_STRUCTURES, etc.
  content     Json     // Exercise content and test cases
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category, difficulty])
  @@index([published])
}

model QuizSubmission {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  quizId     Int
  score      Float
  timestamp  DateTime @default(now())
  answers    Json     // Store answers as JSON for flexibility
}

// New Activity Tracking Tables

model UserActivity {
  id          Int           @id @default(autoincrement())
  user        User          @relation(fields: [userId], references: [id])
  userId      Int
  type        ActivityType  // LOGIN, LESSON_VIEW, QUIZ_SUBMIT, EXERCISE_SOLVE, etc.
  description String        // Human readable description
  metadata    Json?         // Additional data (lesson ID, quiz ID, etc.)
  timestamp   DateTime      @default(now())
  
  @@index([userId, timestamp])
}

model UserSession {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  startTime DateTime @default(now())
  endTime   DateTime?
  duration  Int?     // Duration in seconds
  ipAddress String?
  userAgent String?
  
  @@index([userId, startTime])
}

model DailyActivity {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  date         DateTime @db.Date // Only date part
  loginCount   Int      @default(0)
  studyTime    Int      @default(0) // Total study time in seconds
  lessonsViewed Int     @default(0)
  quizzesTaken Int      @default(0)
  exercisesSolved Int   @default(0)
  pointsEarned Int      @default(0)
  
  @@unique([userId, date])
  @@index([userId, date])
}

model Achievement {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  type        String    // LEARNING, CODING, STREAK, COMMUNITY
  name        String    // Achievement name
  description String    // Achievement description
  unlockedAt  DateTime? // When achievement was unlocked
  points      Int       @default(0) // Points earned for this achievement
  icon        String?   // Icon identifier
  rarity      String    @default("COMMON") // COMMON, RARE, EPIC, LEGENDARY
  
  @@index([userId, type])
  @@index([userId, unlockedAt])
}

enum Role {
  USER
  ADMIN
}

enum PremiumStatus {
  FREE
  STANDARD
  PREMIUM
}

enum ActivityType {
  LOGIN
  LOGOUT
  LESSON_VIEW
  LESSON_COMPLETE
  QUIZ_START
  QUIZ_SUBMIT
  QUIZ_PASS
  EXERCISE_START
  EXERCISE_SUBMIT
  EXERCISE_SOLVE
  PROFILE_UPDATE
  SETTINGS_CHANGE
  DAILY_LOGIN_BONUS
  ACHIEVEMENT_EARNED
  COURSE_ENROLL
  BOOKMARK_ADD
  BOOKMARK_REMOVE
}
